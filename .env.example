APP_NAME=streamalpha
LOG_LEVEL=INFO

KRAKEN_WS_URL=wss://ws.kraken.com/v2
KRAKEN_REST_OHLC_URL=https://api.kraken.com/0/public/OHLC
KRAKEN_SYMBOLS=BTC/USD,ETH/USD,SOL/USD
KRAKEN_OHLC_INTERVAL_MINUTES=5

KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_CLIENT_ID=streamalpha-producer

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=streamalpha
POSTGRES_USER=streamalpha
POSTGRES_PASSWORD=change-me-local-only

TOPIC_RAW_TRADES=raw.trades
TOPIC_RAW_OHLC=raw.ohlc
TOPIC_RAW_HEALTH=raw.health

TABLE_RAW_TRADES=raw_trades
TABLE_RAW_OHLC=raw_ohlc
TABLE_FEATURE_OHLC=feature_ohlc
TABLE_PRODUCER_HEARTBEAT=producer_heartbeat

PRODUCER_SERVICE_NAME=producer
PRODUCER_HEARTBEAT_INTERVAL_SECONDS=15
FEATURE_CONSUMER_GROUP_ID=streamalpha-feature-consumer
FEATURE_SERVICE_NAME=features
FEATURE_FINALIZATION_GRACE_SECONDS=30
FEATURE_BOOTSTRAP_CANDLES=64
INFERENCE_MODEL_PATH=
INFERENCE_REGIME_THRESHOLDS_PATH=
INFERENCE_REGIME_SIGNAL_POLICY_PATH=configs/regime_signal_policy.json
INFERENCE_SERVICE_NAME=inference
INFERENCE_SIGNAL_BUY_PROB_UP=0.55
INFERENCE_SIGNAL_SELL_PROB_UP=0.45
INFERENCE_API_BASE_URL=http://127.0.0.1:8000
DASHBOARD_REFRESH_SECONDS=15
DASHBOARD_RECENT_TRADES_LIMIT=20
DASHBOARD_RECENT_LEDGER_LIMIT=20
STREAMALPHA_RUNTIME_PROFILE=
STREAMALPHA_TRADING_CONFIG_PATH=
STREAMALPHA_STARTUP_REPORT_PATH=artifacts/runtime/startup_report.json

RECONNECT_INITIAL_DELAY_SECONDS=1
RECONNECT_MAX_DELAY_SECONDS=30
RECONNECT_BACKOFF_MULTIPLIER=2.0
RECONNECT_JITTER_SECONDS=0.5

REDPANDA_VERSION=v25.3.10
REDPANDA_CONSOLE_VERSION=v3.5.1
POSTGRES_VERSION=16-alpine
REDPANDA_CONSOLE_PORT=8080
REDPANDA_EXTERNAL_KAFKA_PORT=19092
REDPANDA_EXTERNAL_ADMIN_PORT=19644
REDPANDA_EXTERNAL_SCHEMA_REGISTRY_PORT=18081
REDPANDA_EXTERNAL_PANDAPROXY_PORT=18082
POSTGRES_EXTERNAL_PORT=5432
